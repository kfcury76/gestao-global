# ============================================================================
# VARIÁVEIS DE AMBIENTE - App Gestão (Sistema de Custos)
# Data: 2026-03-17
# ============================================================================
# IMPORTANTE: Copie este arquivo para .env e preencha com valores reais
# ============================================================================

# ============================================================================
# SUPABASE (Cloudfy Self-Hosted)
# ============================================================================

# URL do Supabase (Cloudfy)
VITE_SUPABASE_URL=https://energetictriggerfish-supabase.cloudfy.live

# Chave pública (anon key) - SEGURO expor no frontend
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzcxMjQ3MjE5LCJleHAiOjE4MDI3ODMyMTl9.ptnClNNSMAfgXzL5YkmAjY_Y1NYAOhya1u1Uzoxrolw

# Chave de serviço (service role) - NUNCA expor no frontend!
# Usar APENAS em Edge Functions (backend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret (para Edge Functions)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ============================================================================
# OPENAI API (Para Classificação AI - FASE 2 e 4)
# ============================================================================

# API Key do OpenAI (GPT-4o)
# Necessário para: classify-fixed-cost, classify-transaction-ai
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Modelo a usar (recomendado: gpt-4o ou gpt-4o-mini)
OPENAI_MODEL=gpt-4o

# ============================================================================
# GOOGLE GEMINI API (Alternativa ao OpenAI)
# ============================================================================

# API Key do Google Gemini
# Obter em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo a usar (recomendado: gemini-1.5-flash ou gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash

# ============================================================================
# N8N (Automações)
# ============================================================================

# URL do n8n
N8N_API_URL=https://energetictriggerfish-n8n.cloudfy.live

# API Key do n8n
N8N_API_KEY=your_n8n_api_key_here

# Webhook para envio de PDFs (RH - Google Drive)
N8N_WEBHOOK_PAYSLIP_URL=https://energetictriggerfish-n8n.cloudfy.live/webhook/payslip-upload

# ============================================================================
# GOOGLE DRIVE (Para armazenamento de PDFs - RH)
# ============================================================================

# ID da pasta do Google Drive para contracheques
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ============================================================================
# CONFIGURAÇÕES DO SISTEMA
# ============================================================================

# Ambiente (development, staging, production)
NODE_ENV=development

# URL do app (frontend)
VITE_APP_URL=http://localhost:5173

# URL de produção
VITE_PRODUCTION_URL=https://gestao.cosiararas.com.br

# ============================================================================
# CONFIGURAÇÕES DE CMV (FASE 1)
# ============================================================================

# Período para cálculo de preço médio (em meses)
CMV_AVG_PRICE_PERIOD=3

# Alertas de CMV
CMV_MIN_MARGIN_PERCENT=50  # Margem mínima esperada (%)
CMV_ALERT_THRESHOLD=20     # Variação de preço que dispara alerta (%)

# ============================================================================
# CONFIGURAÇÕES DE CUSTOS FIXOS (FASE 2)
# ============================================================================

# Variação percentual aceitável (alertas)
FIXED_COSTS_VARIANCE_THRESHOLD=20  # %

# Dias antes do vencimento para alertas
FIXED_COSTS_DUE_DATE_ALERT=7  # dias

# ============================================================================
# CONFIGURAÇÕES DE RH/FOLHA (FASE 3)
# ============================================================================

# INSS - Alíquotas (atualizar conforme legislação)
INSS_RATE_1=7.5   # até R$ 1.412,00
INSS_RATE_2=9     # R$ 1.412,01 a R$ 2.666,68
INSS_RATE_3=12    # R$ 2.666,69 a R$ 4.000,03
INSS_RATE_4=14    # R$ 4.000,04 a R$ 7.786,02

# INSS - Faixas (atualizar conforme legislação)
INSS_BRACKET_1=1412.00
INSS_BRACKET_2=2666.68
INSS_BRACKET_3=4000.03
INSS_BRACKET_4=7786.02

# INSS Patronal
INSS_EMPLOYER_RATE=20  # %

# FGTS
FGTS_RATE=8  # %

# Horas mensais (CLT)
MONTHLY_WORKING_HOURS=220

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Habilitar/desabilitar features
VITE_FEATURE_CMV=true
VITE_FEATURE_FIXED_COSTS=true
VITE_FEATURE_PAYROLL=true
VITE_FEATURE_DRE=false  # Fase 5 (não implementada ainda)
VITE_FEATURE_PRICING=false  # Fase 6 (não implementada ainda)

# Habilitar classificação AI
VITE_FEATURE_AI_CLASSIFICATION=true

# ============================================================================
# LOGS E DEBUG
# ============================================================================

# Nível de log (debug, info, warn, error)
LOG_LEVEL=debug

# Habilitar logs de SQL (dev apenas)
DEBUG_SQL=false

# Habilitar logs de Edge Functions
DEBUG_EDGE_FUNCTIONS=true

# ============================================================================
# ANALYTICS (Opcional)
# ============================================================================

# Google Analytics ID
VITE_GA_TRACKING_ID=

# Sentry DSN (error tracking)
VITE_SENTRY_DSN=

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. SEGURANÇA:
#    - NUNCA commite o arquivo .env (está no .gitignore)
#    - Service Role Key NUNCA deve ser exposta no frontend
#    - Use VITE_ prefix para variáveis expostas no frontend
#
# 2. DESENVOLVIMENTO:
#    - Copie este arquivo: cp .env.example .env
#    - Preencha com valores reais
#    - Reinicie o servidor após modificar
#
# 3. PRODUÇÃO:
#    - Configure variáveis no Vercel/Cloudflare
#    - Use secrets para chaves sensíveis
#
# 4. EDGE FUNCTIONS:
#    - Variáveis sem VITE_ são usadas apenas no backend
#    - Configure em: Supabase → Edge Functions → Secrets
#
# ============================================================================
